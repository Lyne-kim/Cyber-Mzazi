<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_screen">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_hero">

            <TextView
                android:id="@+id/menuToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="☰"
                android:textSize="22sp"
                android:textColor="@color/cyber_mzazi_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cyber Mzazi"
                android:textColor="@color/cyber_mzazi_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/headerLogo"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:src="@drawable/cyber_mzazi_logo" />
        </LinearLayout>

        <!-- CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Pairing Section -->
                <LinearLayout
                    android:id="@+id/pairingSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/baseUrlInput"
                        android:hint="@string/base_url_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"/>

                    <EditText
                        android:id="@+id/tokenInput"
                        android:hint="@string/token_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:layout_marginTop="8dp"/>

                    <EditText
                        android:id="@+id/deviceNameInput"
                        android:hint="@string/device_name_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:layout_marginTop="8dp"/>

                    <Button
                        android:id="@+id/saveButton"
                        android:text="@string/save_settings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/scanQrButton"
                        android:text="@string/scan_pairing_qr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Actions -->
                <LinearLayout
                    android:id="@+id/actionsSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/sendTestButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/send_test_payload"/>

                    <Button
                        android:id="@+id/retryQueueButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/retry_queue"/>

                    <Button
                        android:id="@+id/notificationAccessButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/open_notification_access"/>
                </LinearLayout>

                <!-- Filters -->
                <LinearLayout
                    android:id="@+id/filtersSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/allowedPackagesInput"
                        android:hint="@string/allow_packages_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"/>

                    <EditText
                        android:id="@+id/blockedPackagesInput"
                        android:hint="@string/block_packages_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"/>
                </LinearLayout>

                <!-- Status -->
                <LinearLayout
                    android:id="@+id/statusSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status"
                        android:text="@string/no_status_yet"/>
                </LinearLayout>

                <!-- Logs -->
                <LinearLayout
                    android:id="@+id/logSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/recentLogText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status"
                        android:text="@string/no_recent_logs"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- SIDEBAR -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:background="#0A1F44"
        android:orientation="vertical"
        android:layout_gravity="start"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/cyber_mzazi_logo" />

        <TextView
            android:id="@+id/menuHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home"
            style="@style/SidebarItem"/>
        <TextView
            android:id="@+id/menuCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capture"
            style="@style/SidebarItem"/>
        <TextView
            android:id="@+id/menuFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filters"
            style="@style/SidebarItem"/>
        <TextView
            android:id="@+id/menuStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            style="@style/SidebarItem"/>
        <TextView
            android:id="@+id/menuLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logs"
            style="@style/SidebarItem"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
