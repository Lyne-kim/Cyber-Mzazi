<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_screen">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_hero">

            <TextView
                android:id="@+id/menuToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="☰"
                android:textSize="22sp"
                android:textColor="@color/cyber_mzazi_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cyber Mzazi"
                android:textColor="@color/cyber_mzazi_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Pairing Section -->
                <LinearLayout
                    android:id="@+id/pairingSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/baseUrlInput"
                        android:hint="Base URL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"/>

                    <EditText
                        android:id="@+id/tokenInput"
                        android:hint="Token"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:layout_marginTop="8dp"/>

                    <EditText
                        android:id="@+id/deviceNameInput"
                        android:hint="Device Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:layout_marginTop="8dp"/>

                    <Button
                        android:id="@+id/saveButton"
                        android:text="Save"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/scanQrButton"
                        android:text="Scan QR"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Actions -->
                <LinearLayout
                    android:id="@+id/actionsSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/sendTestButton"
                        android:text="Send Test"/>

                    <Button
                        android:id="@+id/retryQueueButton"
                        android:text="Retry Queue"/>

                    <Button
                        android:id="@+id/notificationAccessButton"
                        android:text="Notification Access"/>
                </LinearLayout>

                <!-- Filters -->
                <LinearLayout
                    android:id="@+id/filtersSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/allowedPackagesInput"
                        android:hint="Allowed Packages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/blockedPackagesInput"
                        android:hint="Blocked Packages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Status -->
                <LinearLayout
                    android:id="@+id/statusSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/statusText"
                        android:text="Status"/>
                </LinearLayout>

                <!-- Logs -->
                <LinearLayout
                    android:id="@+id/logSection"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/recentLogText"
                        android:text="Logs"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- SIDEBAR -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:background="#0A1F44"
        android:orientation="vertical"
        android:layout_gravity="start"
        android:padding="16dp">

        <TextView
            android:text="Menu"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/menuHome" android:text="Home" style="@style/SidebarItem"/>
        <TextView android:id="@+id/menuCapture" android:text="Capture" style="@style/SidebarItem"/>
        <TextView android:id="@+id/menuFilters" android:text="Filters" style="@style/SidebarItem"/>
        <TextView android:id="@+id/menuStatus" android:text="Status" style="@style/SidebarItem"/>
        <TextView android:id="@+id/menuLog" android:text="Logs" style="@style/SidebarItem"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>