<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_screen"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_hero"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/menuToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="@string/menu_button_symbol"
                android:textColor="@color/cyber_mzazi_white"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/app_name"
                android:textColor="@color/cyber_mzazi_white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/roleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_menu_button"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="@string/role_child"
                android:textColor="@color/cyber_mzazi_white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/headerLogo"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:src="@drawable/cyber_mzazi_logo" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/roleSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/homepage_title"
                        android:textColor="@color/cyber_mzazi_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/homepage_copy"
                        android:textColor="@color/cyber_mzazi_white" />

                    <Button
                        android:id="@+id/openParentLoginButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/parent_sign_in" />

                    <Button
                        android:id="@+id/openRegisterFamilyButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/register_family_account" />

                    <Button
                        android:id="@+id/openChildLoginButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/child_sign_in" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/parentRoleButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="@string/role_parent" />

                        <Button
                            android:id="@+id/childRoleButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/role_child" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/roleSummaryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/role_child_copy"
                        android:textColor="@color/cyber_mzazi_white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/parentHomeSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auth_nav"
                        android:textColor="@color/cyber_mzazi_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/parentIdentifierInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/parent_identifier_hint"
                        android:inputType="textEmailAddress" />

                    <EditText
                        android:id="@+id/parentPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/parent_password_hint"
                        android:inputType="textPassword" />

                    <Button
                        android:id="@+id/parentLoginButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/parent_sign_in" />

                    <EditText
                        android:id="@+id/parentPhoneCodeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/parent_phone_code_hint"
                        android:inputType="number" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/parentVerifyPhoneButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="@string/verify_phone" />

                        <Button
                            android:id="@+id/parentResendPhoneCodeButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/resend_phone_code" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/refreshParentAlertsButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/refresh_parent_alerts" />

                    <TextView
                        android:id="@+id/parentAlertSummaryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/parent_alerts_not_loaded"
                        android:textColor="@color/cyber_mzazi_white" />

                    <Button
                        android:id="@+id/reviewLatestSafeButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/review_latest_safe" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/approveLogoutButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="@string/approve_logout" />

                        <Button
                            android:id="@+id/denyLogoutButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/deny_logout" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/openParentDashboardButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/open_parent_dashboard" />

                    <Button
                        android:id="@+id/openParentAlertsButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/open_parent_alerts" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/registerFamilySection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/register_family_account"
                        android:textColor="@color/cyber_mzazi_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/registerFamilyNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/register_family_name_hint"
                        android:inputType="textCapWords" />

                    <EditText
                        android:id="@+id/registerParentNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/register_parent_name_hint"
                        android:inputType="textCapWords" />

                    <EditText
                        android:id="@+id/registerParentContactInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/parent_identifier_hint"
                        android:inputType="textEmailAddress" />

                    <EditText
                        android:id="@+id/registerParentPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/parent_password_hint"
                        android:inputType="textPassword" />

                    <EditText
                        android:id="@+id/registerChildNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/register_child_name_hint"
                        android:inputType="textCapWords" />

                    <EditText
                        android:id="@+id/registerChildUsernameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/register_child_username_hint"
                        android:inputType="text" />

                    <EditText
                        android:id="@+id/registerChildPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/register_child_password_hint"
                        android:inputType="textPassword" />

                    <Button
                        android:id="@+id/registerFamilyButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/create_family_account" />

                    <TextView
                        android:id="@+id/registerFamilyStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/register_family_status"
                        android:textColor="@color/cyber_mzazi_white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/childLoginSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/child_sign_in"
                        android:textColor="@color/cyber_mzazi_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/childParentContactInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/parent_identifier_hint"
                        android:inputType="textEmailAddress" />

                    <EditText
                        android:id="@+id/childUsernameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/register_child_username_hint"
                        android:inputType="text" />

                    <EditText
                        android:id="@+id/childPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/register_child_password_hint"
                        android:inputType="textPassword" />

                    <Button
                        android:id="@+id/childLoginButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/child_sign_in" />

                    <TextView
                        android:id="@+id/childLoginStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/child_login_status"
                        android:textColor="@color/cyber_mzazi_white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/childHomeSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/child_home_title"
                        android:textColor="@color/cyber_mzazi_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/goPairChildButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/qr_nav" />

                    <Button
                        android:id="@+id/goCaptureChildButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/capture_nav" />

                    <Button
                        android:id="@+id/goFiltersChildButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/filters_nav" />

                    <TextView
                        android:id="@+id/childSetupStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/child_setup_status_placeholder"
                        android:textColor="@color/cyber_mzazi_white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/qrSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/qr_nav"
                        android:textColor="@color/cyber_mzazi_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/parentChildDeviceNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/parent_child_device_name_hint"
                        android:inputType="textCapWords" />

                    <Button
                        android:id="@+id/createChildDeviceLinkButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/create_child_device_link" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/copyPairingLinkButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="@string/copy_pairing_link" />

                        <Button
                            android:id="@+id/sharePairingLinkButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/share_pairing_link" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/scanQrButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/scan_pairing_qr" />

                    <Button
                        android:id="@+id/openChildDevicesButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/open_child_devices" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_nav"
                        android:textColor="@color/cyber_mzazi_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/baseUrlInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/base_url_hint" />

                    <EditText
                        android:id="@+id/tokenInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/token_hint" />

                    <EditText
                        android:id="@+id/deviceNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/device_name_hint" />

                    <Button
                        android:id="@+id/saveButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/save_settings"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/captureRoleHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/actions_section_copy"
                        android:textColor="@color/cyber_mzazi_white" />

                    <Button
                        android:id="@+id/sendTestButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/send_test_payload" />

                    <Button
                        android:id="@+id/retryQueueButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/retry_queue" />

                    <Button
                        android:id="@+id/notificationAccessButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/open_notification_access" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/filtersSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/allowedPackagesInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:hint="@string/allow_packages_hint" />

                    <EditText
                        android:id="@+id/blockedPackagesInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/block_packages_hint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/statusSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/parentCaptureStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/parent_capture_status_disabled"
                        android:textColor="@color/cyber_mzazi_white" />

                    <Button
                        android:id="@+id/openParentNotificationSettingsButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/open_parent_notification_settings" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/no_status_yet"
                        android:textColor="@color/cyber_mzazi_white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/logSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/recentLogText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status"
                        android:padding="12dp"
                        android:text="@string/no_recent_logs"
                        android:textColor="@color/cyber_mzazi_white" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0A1F44"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/menu_title"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/cyber_mzazi_logo" />

        <TextView
            android:id="@+id/menuHome"
            style="@style/SidebarItem"
